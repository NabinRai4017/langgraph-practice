# Disable LangSmith tracing entirely — using Langfuse instead
LANGCHAIN_TRACING_V2=false

# LLM provider: "deepseek" (default), "openai", or "anthropic"
LLM_PROVIDER=deepseek

# DeepSeek API Key — get yours at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Other provider keys (only needed if switching LLM_PROVIDER)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Langfuse — tracing and observability (https://langfuse.com)
# Get keys from: https://cloud.langfuse.com -> Project Settings -> API Keys
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com   # change to http://localhost:3000 if self-hosting
