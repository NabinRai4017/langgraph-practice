# LLM provider: "deepseek" (default), "openai", or "anthropic"
LLM_PROVIDER=deepseek

# DeepSeek API Key — get yours at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Other provider keys (only needed if switching LLM_PROVIDER)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# LangSmith (optional — for tracing and observability)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=langgraph-agent
